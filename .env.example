SECRET_KEY=<your-secret-key>
JWT_SECRET_KEY=<your-jwt-secret-key>
SESSION_SECRET_KEY=<your-session-secret-key>
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=15
SESSION_TIMEOUT_MINUTES=30
DATABASE_URL=postgresql+psycopg://<username>:<password>@<host>:5432/<database>
TEST_DATABASE_URL=postgresql+psycopg://<username>:<password>@localhost:5432/<test_database>
DB_CONNECT_TIMEOUT_SECONDS=5
DEBUG=false
LOG_LEVEL=INFO
APP_BASE_URL=http://localhost:8000 // Change this to your app's base URL
MAX_LOGIN_ATTEMPTS=5
LOGIN_ATTEMPT_WINDOW_SECONDS=900
MAX_PASSWORD_RESET_ATTEMPTS=5
PASSWORD_RESET_ATTEMPT_WINDOW_SECONDS=900
MAX_EMAIL_VERIFICATION_RESEND=3
EMAIL_VERIFICATION_RESEND_WINDOW_SECONDS=3600
EMAIL_VERIFICATION_TOKEN_EXPIRE_MINUTES=24
ENABLE_EMAIL_VERIFICATION=true
ENABLE_RATE_LIMITING=true
ENABLE_EMAIL_DELIVERY=true
EXPOSE_TOKENS_IN_RESPONSES=false
EMAIL_PROVIDER=resend
EMAIL_FROM=noreply@example.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_FROM_EMAIL=your-email@example.com
SMTP_USERNAME=your-email@example.com
SMTP_PASSWORD=<your-smtp-app-password>
SMTP_USE_TLS=true
SMTP_USE_SSL=false
RESEND_API_KEY=<your-resend-api-key>