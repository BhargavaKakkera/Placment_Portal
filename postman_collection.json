{
  "info": {
    "_postman_id": "placement-portal-sample",
    "name": "Placement Portal - Admin Filters",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "List Verified Companies",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/companies?verified=true&skip=0&limit=50",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "companies"
          ],
          "query": [
            {"key": "verified", "value": "true"},
            {"key": "skip", "value": "0"},
            {"key": "limit", "value": "50"}
          ]
        }
      }
    },
    {
      "name": "List Pending Students",
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "type": "text"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/admin/students?verified=false&skip=0&limit=50",
          "host": [
            "{{baseUrl}}"
          ],
          "path": [
            "admin",
            "students"
          ],
          "query": [
            {"key": "verified", "value": "false"},
            {"key": "skip", "value": "0"},
            {"key": "limit", "value": "50"}
          ]
        }
      }
    }
  ],
  "variable": [
    {"key": "baseUrl", "value": "http://localhost:8000"},
    {"key": "token", "value": ""}
  ]
}
